<IfModule mod_rewrite.c>
    Options -MultiViews -Indexes

    RewriteEngine On

    # Block direct access to Laravel internals when deployed in public_html.
    RewriteRule ^(\.env|\.git|artisan|composer\.(json|lock)|package(-lock)?\.json|phpunit\.xml|vite\.config\.js)$ - [F,L]
    RewriteRule ^(app|bootstrap|config|database|resources|routes|storage|tests|vendor)(/|$) - [F,L]

    # Serve the Laravel public directory as the web root on shared hosting.
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
